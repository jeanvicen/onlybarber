{
  "name": "only-barber",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "build:web": "npm run build:web --workspace @onlybarber/mobile",
    "preview:web": "node scripts/serve-build.mjs",
    "test:preview": "node --test scripts/serve-build.test.mjs scripts/ensure-dependencies.test.mjs",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "engines": {
    "node": ">=20"
  }
}
